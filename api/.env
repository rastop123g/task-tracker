HTTP_HOST=127.0.0.1
HTTP_PORT=8045
APP_LOG=debug
APP_FILTER=debug,async_nats=warn,aws_smithy_runtime=warn,hyper_util=warn,aws_sdk_s3=warn,aws_smithy_http_client=warn
DATABASE_URL=postgres://postgres:postgres@localhost:5432/task_tracker
REDIS_URL=redis://127.0.0.1:6379
NATS_URL=nats://127.0.0.1:4222 
EMAIL_VERIFICATION=false
S3_FORCE_PATH_STYLE=true
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=tasktrackerfiles
S3_REGION=us-east-1
